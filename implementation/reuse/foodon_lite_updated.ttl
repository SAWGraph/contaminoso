###  http://purl.obolibrary.org/obo/FOODON_03411126
obo:FOODON_03411126 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03413807 ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "oncorhynchus"@en ,

###  http://purl.obolibrary.org/obo/UBERON_0001913
obo:UBERON_0001913 rdf:type owl:Class ;
                   rdfs:subClassOf obo:FOODON_02010001 ,
                                   obo:FOODON_03315150 ,
                                   obo:UBERON_0006314 ,
                                   obo:UBERON_0006539 ;
                   obo:IAO_0000115 "An emulsion of fat globules within a fluid that is secreted by the mammary gland during lactation." ;
                   obo:IAO_0000412 <http://langual.org> ,

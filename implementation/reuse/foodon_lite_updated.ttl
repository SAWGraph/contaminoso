                                    ] ;
                    obo:IAO_0000115 "A food product which is derived from or produced by an animal that has a vertibrae."@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:label "vertebrate food product"@en .


###  http://purl.obolibrary.org/obo/FOODON_00001093
obo:FOODON_00001093 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( obo:FOODON_00001173
                                                               [ rdf:type owl:Restriction ;

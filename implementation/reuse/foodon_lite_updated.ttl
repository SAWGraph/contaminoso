###  http://purl.obolibrary.org/obo/FOODON_03414051
obo:FOODON_03414051 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03413807 ;
                    obo:IAO_0000115 "A genus of salmonid fish often called char or charr; some species are called \"trout\". Salvelinus is a member of the subfamily Salmoninae within the family Salmonidae. The genus has a northern circumpolar distribution, and most of its members are typically cold-water fish that primarily inhabit fresh waters. Many species also migrate to the sea."@en ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Salvelinus> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasExactSynonym "charr"@en ,
                                             "salvelinus spp."@en ;
                    oboInOwl:hasNarrowSynonym "Salvelinus Richardson, 1836" ;
                    rdfs:label "char"@en .



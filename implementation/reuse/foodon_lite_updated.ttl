                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:label "white perch"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411156
obo:FOODON_03411156 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411057 ;
                    obo:IAO_0000115 "A legume  is a plant or its fruit or seed in the family *Fabaceae* (or *Leguminosae*). Legumes are grown agriculturally, primarily for their grain seed called pulse, for livestock forage and silage, and as soil-enhancing green manure. Well-known legumes include alfalfa, clover, peas, beans, chickpeas, lentils, lupin bean, mesquite, carob, soybeans, peanuts and tamarind. [https://en.wikipedia.org/wiki/Legume]"@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "fabaceae"@en ;
                    rdfs:label "pod or seed vegetable plant"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411165
obo:FOODON_03411165 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411293 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_126735
                                    ] ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "esox masquinongy"@en ;
                    rdfs:label "muskellunge"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411177
obo:FOODON_03411177 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411557 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_8167
                                    ] ;
                    obo:IAO_0000115 "The yellow perch (Perca flavescens), commonly referred to as perch, is a freshwater perciform fish native to much of North America. The yellow perch was described in 1814 by Samuel Latham Mitchill from New York. It is closely related, and morphologically similar to the European perch (Perca fluviatilis)."@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasExactSynonym "American perch"@en ,
                                             "Dodd fish"@en ,
                                             "Perca flavescens" ,
                                             "coontail"@en ,
                                             "lake perch"@en ,
                                             "raccoon perch"@en ,
                                             "ring-tail perch"@en ,
                                             "ringed perch"@en ,
                                             "striped perch"@en ;
                    oboInOwl:hasSynonym "perca flavescens"@en ;
                    rdfs:label "yellow perch"@en .



###  http://purl.obolibrary.org/obo/FOODON_03411566
obo:FOODON_03411566 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411057 ;
                    obo:IAO_0000115 "Leaf vegetables, also called leafy greens, salad greens, pot herbs, vegetable greens, or simply greens, are plant leaves eaten as a vegetable, sometimes accompanied by tender petioles and shoots."@en ;

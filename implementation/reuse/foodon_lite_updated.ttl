###  http://purl.obolibrary.org/obo/FOODON_03301750
obo:FOODON_03301750 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00002127 ;
                    obo:IAO_0000115 "Forage is a plant material (mainly plant leaves and stems) eaten by grazing livestock.  Historically, the term forage has meant only plants eaten by the animals directly as pasture, crop residue, or immature cereal crops, but it is also used more loosely to include similar plants cut for fodder and carried to the animals, especially as hay or silage."@en ;
                    obo:IAO_0000119 "https://en.wikipedia.org/wiki/Forage"^^xsd:anyURI ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:comment """SIREN DB annotation:
* whole, natural shape FOODON:03430150
* not heat-treated FOODON:03440003
* whole plant or most parts used FOODON:03420150
* non-food animal as food consumer FOODON:03510013
* food animal as consumer FOODON:03510015"""@en ;
                    rdfs:label "forage (animal feed)"@en .



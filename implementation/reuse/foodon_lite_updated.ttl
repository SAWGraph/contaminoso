###  http://purl.obolibrary.org/obo/FOODON_03411297
obo:FOODON_03411297 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00003004 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_7742
                                    ] ;
                    obo:IAO_0000115 "A vertebrate animal is any species of organism within the subphylum Vertebrata (chordates with backbones). Vertebrates represent the overwhelming majority of the phylum Chordata, with currently about 69,276 species described."@en ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Vertebrate> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasBroadSynonym "animal"@en ;
                    rdfs:comment "LanguaL curation note: For a unicellular animal, use *ALGAE OR FUNGUS USED AS FOOD SOURCE*."@en ;
                    rdfs:label "vertebrate animal"@en .



xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000050
obo:BFO_0000050 rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                obo:IAO_0000115 "a core relation that holds between a part and its whole"@en ;
                obo:IAO_0000118 "part_of"@en ;
                obo:IAO_0000412 obo:foodon.owl ,
                                obo:ro.owl ;
                rdfs:label "part of" ,
                           "part of"@en ,
                           "part_of" .


###  http://purl.obolibrary.org/obo/BFO_0000051
obo:BFO_0000051 rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                obo:IAO_0000115 "a core relation that holds between a whole and its part"@en ;
                obo:IAO_0000118 "has_part"@en ;
                obo:IAO_0000412 obo:foodon.owl ,
                                obo:obi.owl ,
                                obo:ro.owl ;
                rdfs:label "has part" ,
                           "has part"@en ,
                           "has_part" .


###  http://purl.obolibrary.org/obo/RO_0000053
obo:RO_0000053 rdf:type owl:ObjectProperty ,
                        owl:InverseFunctionalProperty ;
               obo:IAO_0000115 "Inverse of characteristic_of"@en ;
               obo:IAO_0000118 "bearer_of"@en ,
                               "is bearer of"@en ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "has characteristic"@en .


###  http://purl.obolibrary.org/obo/RO_0000086
obo:RO_0000086 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0000053 ;
               obo:IAO_0000115 "a relation between an independent continuant (the bearer) and a quality, in which the quality specifically depends on the bearer for its existence"@en ;
               obo:IAO_0000118 "has_quality"@en ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "has quality"@en .


###  http://purl.obolibrary.org/obo/RO_0001000
obo:RO_0001000 rdf:type owl:ObjectProperty ;
               obo:IAO_0000115 "a relation between two distinct material entities, the new entity and the old entity, in which the new entity begins to exist when the old entity ceases to exist, and the new entity inherits the significant portion of the matter of the old entity"@en ;
               obo:IAO_0000118 "derives_from"@en ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "derives from"@en .


###  http://purl.obolibrary.org/obo/RO_0002160
obo:RO_0002160 rdf:type owl:ObjectProperty ;
               obo:IAO_0000412 obo:foodon.owl ;
               rdfs:label "only in taxon" ,
                          "only_in_taxon" .


###  http://purl.obolibrary.org/obo/RO_0002162
obo:RO_0002162 rdf:type owl:ObjectProperty ;
               obo:IAO_0000115 "x is in taxon y if an only if y is an organism, and the relationship between x and y is one of: part of (reflexive), developmentally preceded by, derives from, secreted by, expressed." ;
               obo:IAO_0000119 <http://www.ncbi.nlm.nih.gov/pubmed/17921072> ,
                               <http://www.ncbi.nlm.nih.gov/pubmed/20973947> ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "in taxon" .


###  http://purl.obolibrary.org/obo/RO_0002202
obo:RO_0002202 rdf:type owl:ObjectProperty ,
                        owl:TransitiveProperty ;
               obo:IAO_0000412 obo:foodon.owl ;
               rdfs:label "develops from"@en ,
                          "develops_from" .


###  http://purl.obolibrary.org/obo/RO_0002350
obo:RO_0002350 rdf:type owl:ObjectProperty ;
               obo:IAO_0000115 "is member of is a mereological relation between a item and a collection." ;
               obo:IAO_0000118 "is member of" ,
                               "member part of" ;
               obo:IAO_0000119 "SIO" ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "member of"@en .


###  http://purl.obolibrary.org/obo/RO_0003001
obo:RO_0003001 rdf:type owl:ObjectProperty ;
               obo:IAO_0000115 "a produced_by b iff some process that occurs_in b has_output a." ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "produced by"@en .


###  http://purl.obolibrary.org/obo/RO_0009004
obo:RO_0009004 rdf:type owl:ObjectProperty ;
               obo:IAO_0000115 "'has consumer' is a relation between a material entity and an organism in which the former can normally be digested or otherwise absorbed by the latter without immediate or persistent ill effect."@en ;
               obo:IAO_0000412 obo:foodon.owl ,
                               obo:ro.owl ;
               rdfs:label "has consumer"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000020
obo:BFO_0000020 rdf:type owl:Class ;
                obo:IAO_0000111 "specifically dependent continuant"@en ;
                obo:IAO_0000115 "A continuant that inheres in or is borne by other entities. Every instance of A requires some specific instance of B which must always be the same." ,
                                "A continuant that inheres in or is borne by other entities. Every instance of A requires some specific instance of B which must always be the same."@en ,
                                "b is a relational specifically dependent continuant = Def. b is a specifically dependent continuant and there are n &gt; 1 independent continuants c1, … cn which are not spatial regions are such that for all 1  i &lt; j  n, ci  and cj share no common parts, are such that for each 1  i  n, b s-depends_on ci at every time t during the course of b’s existence (axiom label in BFO2 Reference: [131-004])" ,
                                "b is a relational specifically dependent continuant = Def. b is a specifically dependent continuant and there are n &gt; 1 independent continuants c1, … cn which are not spatial regions are such that for all 1  i &lt; j  n, ci  and cj share no common parts, are such that for each 1  i  n, b s-depends_on ci at every time t during the course of b’s existence (axiom label in BFO2 Reference: [131-004])"@en ,
                                "b is a specifically dependent continuant = Def. b is a continuant & there is some independent continuant c which is not a spatial region and which is such that b s-depends_on c at every time t during the course of b’s existence. (axiom label in BFO2 Reference: [050-003])" ,
                                "b is a specifically dependent continuant = Def. b is a continuant & there is some independent continuant c which is not a spatial region and which is such that b s-depends_on c at every time t during the course of b’s existence. (axiom label in BFO2 Reference: [050-003])"@en ;
                obo:IAO_0000412 obo:agro.owl ,
                                obo:envo.owl ,
                                obo:foodon.owl ,
                                obo:obi.owl ,
                                obo:ons.owl ,
                                obo:uberon.owl ;
                rdfs:label "characteristic"@en ,
                           "material property" ,
                           "specifically dependent continuant" ,
                           "specifically dependent continuant"@en .


###  http://purl.obolibrary.org/obo/BFO_0000040
obo:BFO_0000040 rdf:type owl:Class ;
                obo:IAO_0000111 "material entity"@en ;
                obo:IAO_0000115 "An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time." ,
                                "An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time."@en ;
                obo:IAO_0000412 obo:agro.owl ,
                                obo:cdno.owl ,
                                obo:cob.owl ,
                                obo:dron.owl ,
                                obo:envo.owl ,
                                obo:foodon.owl ,
                                obo:obi.owl ,
                                obo:ons.owl ,
                                obo:po.owl ,
                                obo:uberon.owl ;
                rdfs:label "material entity" ,
                           "material entity"@en .


###  http://purl.obolibrary.org/obo/COB_0000022
obo:COB_0000022 rdf:type owl:Class ;
                rdfs:subClassOf obo:UBERON_0000465 ;
                obo:IAO_0000115 "A material entity that is a maximal functionally integrated unit that develops from a program encoded in a genome"@en ;
                obo:IAO_0000412 obo:cob.owl ,
                                obo:foodon.owl ;
                rdfs:label "organism"@en .


###  http://purl.obolibrary.org/obo/FOODON_00001002
obo:FOODON_00001002 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00002403 ;
                    obo:IAO_0000115 "Food material for humans and animals which is processed with the intention that it be consumable as a whole or added to other food products."@en ;
                    obo:IAO_0000118 "Foodon product type"@en ;
                    obo:IAO_0000119 "https://en.wikipedia.org/wiki/Food"^^xsd:anyURI ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:comment "The FoodOn \"food product\"class is provided as a branch under which new food product categories and food products themselves can be placed. Here classes are provided to differentiate a food product by its food composition, processing and/or consumption characteristics. This avoids brand name products but it may include generic food dish categories. It has a much greater depth and polyhierarchy than other agency product type schemes have in an effort to group related products together.  The upper level basis of this tree originated in the environment ontology (ENVO) and from the US Code of Federal Regulations."@en ;
                    rdfs:label "food product"@en .


###  http://purl.obolibrary.org/obo/FOODON_00001006
obo:FOODON_00001006 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00001092 ,
                                    obo:FOODON_00005501 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0001000 ;
                                      owl:someValuesFrom obo:FOODON_03411134
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002350 ;
                                      owl:someValuesFrom obo:FOODON_03400150
                                    ] ;
                    obo:IAO_0000115 "A food product made of meat, the skeletal muscle and associated fat, and other edible tissues such as organs, livers, skin, brains, bone marrow, kidneys, or lungs, of mammals." ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Meat> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:label "mammalian meat food product"@en .


###  http://purl.obolibrary.org/obo/FOODON_00001015
obo:FOODON_00001015 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00001002 ,
                                    obo:FOODON_00004331 ;
                    obo:IAO_0000115 "A food product which has as a defining ingredient some plant material."@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    dc:contributor <https://orcid.org/0000-0002-8844-9165> ;
                    rdfs:label "plant food product"@en .


###  http://purl.obolibrary.org/obo/FOODON_00001041
obo:FOODON_00001041 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( obo:FOODON_00001134
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty obo:RO_0001000 ;
                                                                 owl:someValuesFrom obo:NCBITaxon_9913
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf obo:FOODON_00001134 ,
                                    obo:FOODON_02020889 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0001000 ;
                                      owl:someValuesFrom obo:NCBITaxon_9913
                                    ] ;
                    obo:IAO_0000115 "A food product that is derived from some cow."@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    terms:date "2025-02-01T09:59:11Z"^^xsd:dateTime ;
                    rdfs:label "cow food product"@en .


###  http://purl.obolibrary.org/obo/FOODON_00001092
obo:FOODON_00001092 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( obo:FOODON_00004242
                                                               [ rdf:type owl:Restriction ;

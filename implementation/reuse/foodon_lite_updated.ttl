###  http://purl.obolibrary.org/obo/FOODON_03412112
obo:FOODON_03412112 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411433 ;
                    obo:IAO_0000115 "Mollusca is a large phylum of invertebrate animals whose members are known as molluscs or mollusks. Molluscs are the largest marine phylum, comprising about 23% of all the named marine organisms. Numerous molluscs also live in freshwater and terrestrial habitats. [https://en.wikipedia.org/wiki/Mollusca]"@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasExactSynonym "Mollusca" ,
                                             "mollusk"@en ;
                    rdfs:label "mollusc"@en .


###  http://purl.obolibrary.org/obo/FOODON_03412113
obo:FOODON_03412113 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00005705 ,
                                    obo:FOODON_03412112 ;
                    obo:IAO_0000115 "Bivalvia, in previous centuries referred to as the *Lamellibranchiata* and *Pelecypoda*, is a class of marine and freshwater molluscs that have laterally compressed bodies enclosed by a shell consisting of two hinged parts. Bivalves as a group have no head and they lack some usual molluscan organs like the radula and the odontophore. They include the clams, oysters, cockles, mussels, scallops, and numerous other families that live in saltwater, as well as a number of families that live in freshwater.[https://en.wikipedia.org/wiki/Bivalvia]"@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "bivalvia"@en ,
                                        "lamellibranchiata"@en ,
                                        "pelecypod"@en ,
                                        "pelecypoda"@en ;
                    rdfs:label "bivalve"@en .



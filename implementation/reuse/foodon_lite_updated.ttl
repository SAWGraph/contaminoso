###  http://purl.obolibrary.org/obo/FOODON_03411222
obo:FOODON_03411222 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411021 ,
                                    obo:FOODON_03411297 ;
                    obo:IAO_0000115 "A gill-bearing aquatic craniate animal that lacks limbs with digits."@en ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Fish> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:comment "\"Most fish are ectothermic ('cold-blooded'), allowing their body temperatures to vary as ambient temperatures change, though some of the large active swimmers like white shark and tuna can hold a higher core temperature.\" - https://en.wikipedia.org/wiki/Fish"@en ;
                    rdfs:label "fish species"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411223
obo:FOODON_03411223 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_02020797 ,
                                    obo:FOODON_03412113 ;
                    obo:IAO_0000115 "A whole mussel."@en ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Mussel> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    obo:IAO_0000600 "Mussel is the common name used for members of several families of bivalve molluscs, from saltwater and freshwater habitats. These groups have in common a shell whose outline is elongated and asymmetrical compared with other edible clams, which are often more or less rounded or oval."@en ;
                    terms:date "2025-02-01T09:59:11Z"^^xsd:dateTime ;
                    schema:image "https://upload.wikimedia.org/wikipedia/commons/thumb/4/45/CornishMussels.JPG/640px-CornishMussels.JPG"^^xsd:anyURI ;
                    oboInOwl:hasBroadSynonym "palaeoheterodonta"@en ,
                                             "pteriomorphia"@en ;
                    oboInOwl:hasExactSynonym "mytilidae"@en ;
                    rdfs:comment "A mussel which is dead or alive and has a relatively intact body."@en ;
                    rdfs:label "mussel"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411232
obo:FOODON_03411232 rdf:type owl:Class ;

###  http://purl.obolibrary.org/obo/NCBITaxon_9900
obo:NCBITaxon_9900 rdf:type owl:Class ;
                   rdfs:subClassOf obo:NCBITaxon_27592 ;
                   obo:IAO_0000115 "Members of the genus *Bison* are large, even-toed ungulates within the subfamily *Bovinae*. Two extant and four extinct species are recognized. The surviving species are the American bison, also known as the American buffalo (although it is only distantly related to the true buffalo), *Bison bison*, found in North America, and the European bison, or wisent (*Bison bonasus*), found in Europe and the Caucasus. The North American species is composed of two subspecies, the plains bison, *Bison bison bison*, and the wood bison, *Bison bison athabascae*. While all bison species are usually grouped into their own genus, they are sometimes included in the closely related genus *Bos*, together with cattle, gaur, kouprey and yaks, with which bison have a limited ability to interbreed."@en ;
                   obo:IAO_0000119 "WIKIPEDIA:Bison" ;
                   obo:IAO_0000412 obo:foodon.owl ,
                                   obo:ncbitaxon.owl ;
                   oboInOwl:hasSynonym "bison spp."@en ;
                   rdfs:label "Bison" .


###  http://purl.obolibrary.org/obo/NCBITaxon_9903
obo:NCBITaxon_9903 rdf:type owl:Class ;
                   rdfs:subClassOf obo:NCBITaxon_27592 ;
                   obo:IAO_0000412 obo:foodon.owl ,
                                   obo:ncbitaxon.owl ;
                   oboInOwl:hasExactSynonym "cattle" ;
                   rdfs:label "Bos" .


###  http://purl.obolibrary.org/obo/NCBITaxon_9913
obo:NCBITaxon_9913 rdf:type owl:Class ;
                   rdfs:subClassOf obo:NCBITaxon_9903 ;
                   obo:IAO_0000115 "Cattle (colloquially cows) are the most common type of large domesticated ungulates. They are a prominent modern member of the subfamily *Bovinae*, are the most widespread species of the genus *Bos*, and are most commonly classified collectively as *Bos taurus*... with three subspecies: *Bos taurus primigenius, Bos taurus indicus, Bos taurus taurus*."@en ;
                   obo:IAO_0000118 "cattle"@en ;
                   obo:IAO_0000119 <https://en.wikipedia.org/wiki/Cattle> ;
                   obo:IAO_0000412 obo:foodon.owl ,
                                   obo:ncbitaxon.owl ;
                   oboInOwl:hasExactSynonym "Bos taurus Linnaeus, 1758"@en ,
                                            "bovine" ,
                                            "cow" ,
                                            "dairy cow" ,
                                            "domestic cattle" ,
                                            "domestic cow" ,
                                            "ox" ;
                   rdfs:label "Bos taurus" ;
                   rdfs:seeAlso <https://en.wikipedia.org/wiki/List_of_cattle_breeds> .



###  http://purl.obolibrary.org/obo/FOODON_00001134
obo:FOODON_00001134 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( obo:FOODON_00001006
                                                               [ rdf:type owl:Restriction ;

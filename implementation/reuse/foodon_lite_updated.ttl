                    obo:IAO_0000412 obo:foodon.owl ;
                    schema:image "https://upload.wikimedia.org/wikipedia/commons/3/3b/LittleNeck_clams_USDA96c1862.jpg"@en ;
                    rdfs:label "clam species"@en .



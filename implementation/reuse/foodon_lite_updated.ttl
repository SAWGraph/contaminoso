###  http://purl.obolibrary.org/obo/FOODON_03411818
obo:FOODON_03411818 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411581 ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "centrarchidae"@en ;

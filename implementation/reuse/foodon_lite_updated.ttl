                                        "zea mays"@en ;
                    rdfs:comment "LanguaL curation note: Use 'field corn' for any breakfast cereals or snack foods having 'corn' as the main ingredient."@en ;
                    rdfs:label "Zia mays plant"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411236
obo:FOODON_03411236 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00002616 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_9102
                                    ] ;
                    obo:IAO_0000115 "The turkey is a large bird in the genus Meleagris, which is native to the Americas. Males of both turkey species have a distinctive fleshy wattle or protuberance that hangs from the top of the beak (called a snood). They are among the largest birds in their ranges. As in many galliformes, the male is larger and much more colorful than the female."@en ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Turkey_(bird)> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasBroadSynonym "turkey"@en ;
                    oboInOwl:hasSynonym "meleagris spp."@en ;
                    rdfs:label "turkey (bird)"@en .



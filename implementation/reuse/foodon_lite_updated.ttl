obo:FOODON_03411349 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00002507 ;
                    obo:IAO_0000115 "Calves are the young of domestic cattle. Calves are reared to become adult cattle, or are slaughtered for their meat, called veal."@en ;

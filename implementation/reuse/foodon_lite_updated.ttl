obo:FOODON_03411331 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03412113 ;
                    obo:IAO_0000115 "Clam is a common name for several kinds of bivalve molluscs. The word is often applied only to those that are edible and live as infauna, spending most of their lives halfway buried in the sand of the seafloor."@en ;

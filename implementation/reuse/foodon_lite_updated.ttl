###  http://purl.obolibrary.org/obo/FOODON_03413808
obo:FOODON_03413808 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411365 ;
                    obo:IAO_0000115 "Esociformes are a small order of ray-finned fish, with two families, the *Umbridae* (mudminnows) and the *Esocidae* (pikes). The pikes of genus *Esox* give the order its name."@en ;

                    rdfs:label "pacific salmon"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411129
obo:FOODON_03411129 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411592 ;
                    obo:IAO_0000115 "Salmonidae is a family of ray-finned fish, the only living family currently placed in the order Salmoniformes. It includes salmon, trout, chars, freshwater whitefishes, and graylings, which collectively are known as the salmonids. The Atlantic salmon and trout of the genus *Salmo* give the family and order their names. [https://en.wikipedia.org/wiki/Salmonidae]"@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "salmonidae"@en ;
                    rdfs:label "trout and salmon family"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411134
obo:FOODON_03411134 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00005501 ,
                                    obo:FOODON_03411297 ;
                    obo:IAO_0000115 "Mammals (from Latin mamma \"breast\") are vertebrate animals constituting the class Mammalia, and characterized by the presence of mammary glands which in females produce milk for feeding (nursing) their young, a neocortex (a region of the brain), fur or hair, and three middle ear bones."@en ;
                    obo:IAO_0000119 "https://en.wikipedia.org/wiki/Mammal"^^xsd:anyURI ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:label "mammal"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411136
obo:FOODON_03411136 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00005689 ,
                                    obo:FOODON_03411134 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_9823
                                    ] ;
                    obo:IAO_0000115 "Suidae is a family of artiodactyl mammals which are commonly called pigs, hogs or boars."@en ;
                    obo:IAO_0000119 "https://en.wikipedia.org/wiki/Suidae"@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    obo:IAO_0000600 "In addition to numerous fossil species, 17 extant species are currently recognized (or 18 counting domestic pigs and wild boars separately), classified into between four and eight genera. The family includes the domestic pig, Sus scrofa domesticus or Sus domesticus, in addition to numerous species of wild pig, such as babirusas and warthogs. All suids, or swine, are native to the Old World, ranging from Asia to Europe and Africa. [Wikipedia]"@en ;
                    oboInOwl:hasExactSynonym "porcine"@en ,
                                             "sus domesticus"@en ,
                                             "sus scrofa"@en ,
                                             "sus scrofa domesticus"@en ;
                    oboInOwl:hasNarrowSynonym "Sus scrofa Linnaeus, 1758" ,
                                              "hog"@en ,
                                              "pig"@en ;
                    rdfs:label "swine"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411143

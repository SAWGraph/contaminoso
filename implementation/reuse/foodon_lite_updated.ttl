###  http://purl.obolibrary.org/obo/FOODON_03411398
obo:FOODON_03411398 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03412004 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_283036
                                    ] ;
                    obo:IAO_0000115 "A freshwater perciform fish native to most of Canada and to the Northern United States."@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasExactSynonym "sander vitreus"@en ,
                                             "stizostedion vitreum"@en ,
                                             "stizostedion vitreum vitreum"@en ,
                                             "walleye" ,
                                             "walleye"@en ,
                                             "yellow pike"@en ;
                    rdfs:label "walleye pike"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411409
obo:FOODON_03411409 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03411818 ;
                    obo:IAO_0000115 "The species of this genus are known as crappies and are extremely popular game fish. The genus has two species the white and black crappie. Crappie of both species are sometimes referred to as papermouths, calico bass, and strawberry bass. Both species of crappie feed on minnows as adults. Both species spawn in the early spring when the water temperature nears 64 to 68 degrees. Crappie create a nest in fine silt or gravel, and the nests are often congregated in very high densities in shallow waters. ("@en ;
                    obo:IAO_0000119 "WIKIPEDIA:White_crappie)" ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    oboInOwl:hasSynonym "pomoxis spp."@en ;
                    rdfs:label "crappie"@en .


###  http://purl.obolibrary.org/obo/FOODON_03411433
obo:FOODON_03411433 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00002581 ,
                                    obo:FOODON_03411021 ;
                    obo:IAO_0000115 "The term shellfish is used both broadly and specifically. For regulatory purposes it is often narrowly defined as filter-feeding molluscs such as clams, mussels, and oyster to the exclusion of crustaceans and all else. Although their shells may differ, all shellfish are invertebrates."@en ;
                    obo:IAO_0000119 <https://en.wikipedia.org/wiki/Shellfish> ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:comment "Covers both freshwater and saltwater organisms"@en ;
                    rdfs:label "shellfish species"@en .



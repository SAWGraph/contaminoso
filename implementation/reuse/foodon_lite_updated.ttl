                    oboInOwl:hasSynonym "flower, root, stem or leaf"@en ,
                                        "leaf, flower, root or stem"@en ,
                                        "stem, leaf, flower or root"@en ;
                    rdfs:label "root, stem, leaf or flower"@en .


###  http://purl.obolibrary.org/obo/FOODON_03420150
obo:FOODON_03420150 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00004331 ;
                    obo:IAO_0000115 "A whole plant or one or more pieces from one or more plants."@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:label "plant (whole or piece(s))"@en .


###  http://purl.obolibrary.org/obo/FOODON_03420164
obo:FOODON_03420164 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( obo:FOODON_03420116
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty obo:RO_0002162 ;
                                                                 owl:someValuesFrom obo:NCBITaxon_33208
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf obo:FOODON_03420116 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty obo:RO_0002162 ;
                                      owl:someValuesFrom obo:NCBITaxon_33208
                                    ] ;
                    obo:IAO_0000115 "Material that derives from one or more animals"@en ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    terms:date "2023-08-01T21:25:29Z"^^xsd:dateTime ;
                    rdfs:comment "Langual note: Includes eggs and milk that, although separated from the animal, are produced as integral parts and are affected by the animal's food intake and metabolism."@en ,
                                 "This branch isn't necessarily food material"@en ;
                    rdfs:label "animal material"@en .


###  http://purl.obolibrary.org/obo/FOODON_03420173
obo:FOODON_03420173 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_03420127 ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:comment "LanguaL curation note: Used when the entire animal body is the food source. Head or tail may have been removed. Use the appropriate narrower term depending on the presence or absence of skin, feathers, scales, fins and/or entrails. The body may have been cut into pieces or disintegrated."@en ;
                    rdfs:label "whole animal or most parts used"@en .



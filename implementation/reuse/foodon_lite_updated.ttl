                    rdfs:subClassOf obo:FOODON_02010020 ,
                                    obo:FOODON_03420173 ;
                    obo:IAO_0000412 obo:foodon.owl ;
                    rdfs:label "animal carcass (skinned, defeathered or scaled, not eviscerated)"@en .


###  http://purl.obolibrary.org/obo/FOODON_03420148
obo:FOODON_03420148 rdf:type owl:Class ;
                    rdfs:subClassOf obo:FOODON_00004333 ;
                    obo:IAO_0000115 "The parts of a plant that are not fruit or seed."@en ;

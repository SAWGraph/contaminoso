                   oboInOwl:hasExactSynonym "mammal milk"@en ;
                   rdfs:comment "LanguaL curation note: See scope note for *MILK OR MILK COMPONENT*. for lowfat milk use *FAT PARTIALLY REMOVED*; for skim milk, use *FAT FULLY REMOVED* (both found in D3. TREATMENT APPLIED)."@en ;
                   rdfs:label "milk" .


